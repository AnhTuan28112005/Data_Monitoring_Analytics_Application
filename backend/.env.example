# Backend env vars (override defaults in app/core/config.py)
APP_NAME=World Monitor
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# CCXT exchange used for crypto OHLCV (binance/kraken/coinbase ...)
CRYPTO_EXCHANGE=binance

# Polling intervals (seconds)
PRICE_POLL_INTERVAL=5
OHLCV_POLL_INTERVAL=15
NEWS_POLL_INTERVAL=300

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL (optional — app works without it, but no data persistence)
# DATABASE_URL=postgresql://postgres:123456@localhost:5432/world_monitor_db
